# This root repo tracks ONLY the engineering handbook (README + docs/).
# Each project directory is its own independent git repository — see README.md,
# section "Why the Repos Are Organized This Way". Nesting git repos causes
# confusing "gitlink" behavior, so we exclude them here entirely.
project-*/

# OS noise
.DS_Store

# Local tooling config (Claude Code dev-server launcher) — machine-specific,
# so it stays out of version control, same as .vscode/ or .idea/ on many teams.
.claude/
